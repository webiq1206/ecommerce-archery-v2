modules = ["nodejs-24", "postgresql-16"]

run = "pnpm run dev"

[deployment]
run = ["pnpm", "run", "start"]
build = ["pnpm", "run", "build"]
deploymentTarget = "autoscale"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
[workflows.workflow.tasks.args]
command = "pnpm run dev"
waitForPort = 3000

[nix]
channel = "stable-25_05"
